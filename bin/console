#!/usr/bin/env php
<?php

declare(strict_types=1);

use App\Console\Bootstrap;
use Jotup\Application\Console;

require dirname(__DIR__) . '/vendor/autoload.php';

defined('APP_CORE_PATH') or define('APP_CORE_PATH', dirname(__DIR__) . DIRECTORY_SEPARATOR);
defined('APP_DEBUG') or define('APP_DEBUG', false);
defined('APP_CONTEXT') or define('APP_CONTEXT', 'cli');

$app = new Console(new Bootstrap());

$app->run();
