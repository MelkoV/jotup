{
    "name": "melkov/jotup",
    "type": "project",
    "description": "",
    "keywords": [],
    "license": "MIT",
    "authors": [
        {
            "name": "Anton Smorodin",
            "email": "ant-smorodin@ya.ru",
            "homepage": "https://github.com/MelkoV"
        }
    ],
    "require": {
        "php": "~8.5",
        "ext-pdo": "*",
        "firebase/php-jwt": "^7.0",
        "openswoole/core": "^26.2",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "ramsey/uuid": "^4.9",
        "symfony/console": "^7.4",
        "yiisoft/cache-apcu": "^1.1",
        "yiisoft/db": "^1.3",
        "yiisoft/db-migration": "^1.2",
        "yiisoft/db-pgsql": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Jotup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "console": "@php bin/console",
        "db:smoke": "@php bin/console app:db:smoke",
        "migrate": "@php bin/console",
        "migrate:create": "@php bin/console migrate:create",
        "migrate:up": "@php bin/console migrate:up",
        "migrate:down": "@php bin/console migrate:down",
        "migrate:history": "@php bin/console migrate:history",
        "migrate:new": "@php bin/console migrate:new",
        "migrate:redo": "@php bin/console migrate:redo"
    },
    "extra": {
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {

        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "openswoole/ide-helper": "^26.2",
        "phpunit/phpunit": "^11"
    }
}
